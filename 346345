    cur.BackgroundColor3 = C_WHITE
    cur.BorderSizePixel  = 0
    cur.ZIndex           = 6
    cur.Parent           = terminal

    local function moveCur()
        local tw = TextService:GetTextSize(kb.Text, FS, FONT, Vector2.new(9999, 20)).X
        cur.Position = UDim2.new(0, inputOffX + tw + 1, 0, rowY + 2)
    end
    moveCur()
    kb:GetPropertyChangedSignal("Text"):Connect(moveCur)

    local blinking = true
    task.spawn(function()
        while blinking and screenGui.Parent do
            cur.BackgroundTransparency = 0
            task.wait(0.53)
