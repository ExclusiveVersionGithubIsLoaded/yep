local function addLabel(txt, col, y)
    local l = Instance.new("TextLabel")
    l.Size                   = UDim2.new(1, -(PAD*2), 0, LH)
    l.Position               = UDim2.new(0, PAD, 0, y)
    l.BackgroundTransparency = 1
    l.Text                   = txt
    l.TextColor3             = col or C_WHITE
    l.TextSize               = FS
    l.Font                   = FONT
    l.TextXAlignment         = Enum.TextXAlignment.Left
    l.TextYAlignment         = Enum.TextYAlignment.Center
    l.ZIndex                 = 4
    l.Parent                 = terminal
    terminal.CanvasSize = UDim2.new(0, 0, 0, y + LH + 20)
terminal.CanvasPosition = Vector2.new(0, terminal.CanvasSize.Y.Offset)
    return l
end

local function addSystemLabel(text, color)
    local lbl = addLabel(text, color, lineY)
    lbl:SetAttribute("System", true)
