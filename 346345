            cur.BackgroundTransparency = 1
            task.wait(0.53)
        end
        cur.BackgroundTransparency = 0
        cur.Visible = false
    end)

    task.wait(0.05)
    kb:CaptureFocus()
    windowFocused = true

    kb.FocusLost:Connect(function(enterPressed)
        if not enterPressed then
            onFocusLostExternal()
            return
        end

        inputLocked = true
        blinking    = false
        kb.TextEditable = false

